<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- 顶部标题和返回按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#2196F3"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="排行榜"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_revert"
            android:scaleType="center"
            android:contentDescription="返回" />
    </LinearLayout>

    <!-- 模式选择 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#FFFFFF">

        <Button
            android:id="@+id/btn_easy_mode"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="简单模式"
            android:textSize="16sp"
            android:background="#E3F2FD"
            android:textColor="#2196F3"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_hard_mode"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="困难模式"
            android:textSize="16sp"
            android:background="#F5F5F5"
            android:textColor="#D01010" />
    </LinearLayout>

    <!-- 列表标题 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="#CDE4CF"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="排名"
            android:textSize="14sp"
            android:textColor="#4CAF50"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="玩家"
            android:textSize="14sp"
            android:textColor="#4CAF50"
            android:textStyle="bold"
            android:paddingStart="16dp" />

        <TextView
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="胜率"
            android:textSize="14sp"
            android:textColor="#4CAF50"
            android:textStyle="bold"
            android:gravity="end" />
    </LinearLayout>

    <!-- 排行榜列表 -->
    <ListView
        android:id="@+id/lv_ranking"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#EEEEEE"
        android:dividerHeight="1dp"
        android:paddingVertical="8dp"
        android:background="#FFFFFF" />

    <!-- 空列表提示 -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="暂无排行榜数据\n"
        android:textSize="16sp"
        android:textColor="#999999"
        android:gravity="center"
        android:textAlignment="center"
        android:lineSpacingExtra="8dp"
        android:visibility="visible" />

    <!-- 底部当前用户排名 -->
    <LinearLayout
        android:id="@+id/layout_current_rank"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:elevation="4dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="我的排名: "
            android:textSize="14sp"
            android:textColor="#666666" />

        <TextView
            android:id="@+id/tv_current_rank"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#--"
            android:textSize="14sp"
            android:textColor="#2196F3"
            android:textStyle="bold"
            android:layout_marginEnd="16dp" />

        <TextView
            android:id="@+id/tv_current_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="14sp"
            android:textColor="#333333"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/tv_current_win_rate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--%"
            android:textSize="14sp"
            android:textColor="#4CAF50"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>