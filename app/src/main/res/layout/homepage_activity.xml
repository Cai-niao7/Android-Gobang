<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 顶部标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="#2196F3"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <!-- 返回按钮 -->
            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_menu_revert"
                android:scaleType="center"
                android:contentDescription="返回" />

            <!-- 标题 -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="个人信息"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center" />

            <!-- 切换账户按钮 -->
            <ImageButton
                android:id="@+id/btn_switch_account"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_menu_rotate"
                android:scaleType="center"
                android:contentDescription="切换账户"
                android:padding="8dp" />
        </LinearLayout>

        <!-- 个人信息卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="642dp"
            android:layout_margin="16dp"
            android:background="@drawable/rankbg"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- 头像部分 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <!-- 头像（点击可更换） -->
                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:id="@+id/iv_avatar"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:background="#E0E0E0"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:padding="4dp"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/sym_def_app_icon" />

                    <!-- 更换头像提示 -->
                    <TextView
                        android:id="@+id/tv_change_avatar_hint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignStart="@id/iv_avatar"
                        android:layout_alignEnd="@id/iv_avatar"
                        android:layout_alignBottom="@id/iv_avatar"
                        android:background="#E3F2FD"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:padding="4dp"
                        android:text="点击更换头像"
                        android:textColor="#2196F3"
                        android:textSize="12sp" />
                </RelativeLayout>

            </LinearLayout>

            <!-- 用户名部分 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <!-- 用户名（点击可修改） -->
                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tv_username"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#F8F8F8"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:padding="12dp"
                        android:paddingHorizontal="24dp"
                        android:text="玩家001"
                        android:textColor="#333333"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <!-- 修改用户名提示 -->
                    <TextView
                        android:id="@+id/tv_change_username_hint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tv_username"
                        android:layout_centerHorizontal="true"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="4dp"
                        android:text="点击修改用户名"
                        android:textColor="#666666"
                        android:textSize="12sp" />
                </RelativeLayout>

            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="24dp"
                android:background="#EEEEEE" />

            <!-- 游戏统计标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="游戏统计"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 简单模式统计 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="#E8F5E9"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="简单模式"
                    android:textColor="#4CAF50"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_easy_win_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="胜率: 70.0%"
                    android:textColor="#333333"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_easy_total_games"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="总对局: 10"
                        android:textColor="#666666"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tv_easy_win_games"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="胜利: 7"
                        android:textColor="#666666"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 困难模式统计 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFF3E0"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="困难模式"
                    android:textColor="#FF9800"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_hard_win_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="胜率: 37.5%"
                    android:textColor="#333333"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_hard_total_games"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="总对局: 8"
                        android:textColor="#666666"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tv_hard_win_games"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="胜利: 3"
                        android:textColor="#666666"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 底部提示 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="提示：点击头像或用户名可直接修改"
            android:textSize="12sp"
            android:textColor="#999999"
            android:gravity="center"
            android:padding="16dp" />

    </LinearLayout>
</LinearLayout>